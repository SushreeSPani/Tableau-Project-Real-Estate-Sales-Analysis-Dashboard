      <column caption='Sales Category' datatype='string' name='[Calculation_0253209054736384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sale Amount]&gt;1000000 THEN &apos;High&apos;&#13;&#10;ELSEIF [Sale Amount]&gt;=500000 and [Sale Amount]&lt;=1000000 THEN &apos;Medium&apos;&#13;&#10;ELSE &apos;Low&apos;&#13;&#10;END' />
      </column>
